#!/usr/bin/env python3

import sys
import requests
import re
from pathlib import Path
from fnmatch import fnmatch

host1 = "https://git.henderkes.com"
host2 = "https://git.static-php.dev"

def get_remote_packages(host, owner, password, pkg_type):
    url = f"{host}/api/v1/packages/{owner}"
    params = {"type": pkg_type, "limit": 1000}
    response = requests.get(url, params=params, auth=(owner, password))
    response.raise_for_status()
    return response.json()

def get_remote_package_archs(host, owner, password, pkg_type, name, version):
    url = f"{host}/api/v1/packages/{owner}/{pkg_type}/{name}/{version}/files"
    resp = requests.get(url, auth=(owner, password))
    archs = set()
    if resp.status_code == 200:
        for f in resp.json():
            fname = f.get('name', '')
            for arch in ['x86_64', 'aarch64', 'amd64', 'arm64']:
                if arch in fname:
                    archs.add(arch)
    return archs

def get_package_info(pkg_file, pkg_type):
    if pkg_type == 'rpm':
        match = re.match(r'(.+)-([0-9][^-]*)-(\d+)\.(el\d+)\.(x86_64|aarch64)\.rpm', pkg_file.name)
        if not match:
            return None
        name, ver, rel, el_version, arch = match.groups()
        version = f"{ver}-{rel}.{el_version}"
    elif pkg_type == 'debian':
        match = re.match(r'(.+?)_(\d+[^_]+)_(amd64|arm64)\.deb', pkg_file.name)
        if not match:
            return None
        name, version, arch = match.groups()
    elif pkg_type == 'alpine':
        match = re.match(r'(.+?)-(\d+\..+)\.(x86_64|aarch64)\.apk', pkg_file.name)
        if not match:
            return None
        name, version, arch = match.groups()
    else:
        match = re.match(r'(.+?)-(\d+\..+)\.(x86_64|aarch64)\.pkg\.tar\.zst', pkg_file.name)
        if not match:
            return None
        name, version, arch = match.groups()

    full_name = f"{name.replace('_', '-') if pkg_type == 'debian' else name}-{version}"
    return name, version, arch, full_name

def list_packages(host, owner, password, pkg_type, pattern=None):
    local_names = set()
    has_local_files = False
    clean_pattern = pattern
    if pattern:
        # We strip the extension from the pattern if it's there, to match against remote names.
        if pkg_type == 'rpm' and pattern.endswith('.rpm'):
            clean_pattern = pattern[:-4]
        elif pkg_type == 'debian' and pattern.endswith('.deb'):
            clean_pattern = pattern[:-4]
        elif pkg_type == 'alpine' and pattern.endswith('.apk'):
            clean_pattern = pattern[:-4]

        # If the pattern is quoted and contains wildcards, Path.glob handles it.
        # But if the user passed a pattern that doesn't match anything locally, local_names remains empty.
        for pkg_file in Path(".").glob(pattern):
            if pkg_file.is_file():
                info = get_package_info(pkg_file, pkg_type)
                if info:
                    has_local_files = True
                    local_names.add(info[3])

    packages = get_remote_packages(host, owner, password, pkg_type)
    for pkg in packages:
        full_name = f"{pkg['name']}-{pkg['version']}"
        show = False
        if pattern:
            # If we found local files matching the pattern, ONLY show remote packages that match those local files.
            if has_local_files:
                if full_name in local_names:
                    show = True
            else:
                # Fallback: If NO local files were found, we match against remote names directly (manual usage).
                if any(fnmatch(text, p) for text in [pkg['name'], full_name] for p in [pattern, clean_pattern]):
                    show = True
        else:
            show = True

        if show:
            archs = get_remote_package_archs(host, owner, password, pkg_type, pkg['name'], pkg['version'])
            arch_suffix = f" [{', '.join(sorted(archs))}]" if archs else ""
            print(f"{full_name}{arch_suffix}")

def delete_packages(host, owner, password, pkg_type, pattern):
    packages = get_remote_packages(host, owner, password, pkg_type)
    for pkg in packages:
        full_name = f"{pkg['name']}-{pkg['version']}"
        if fnmatch(full_name, pattern):
            print(f"Deleting: {pkg['name']} {pkg['version']}")
            if pkg_type == 'debian':
                for arch in ['amd64', 'arm64']:
                    url = f"{host}/api/packages/{owner}/debian/pool/php-zts/main/{pkg['name']}/{pkg['version']}/{arch}"
                    resp = requests.delete(url, auth=(owner, password))
                    print(f"Delete {arch} response: {resp.status_code}")
                    if resp.status_code not in [200, 204, 404]:
                        print(f"Error: {resp.text}")
            else:
                url = f"{host}/api/v1/packages/{owner}/{pkg_type}/{pkg['name']}/{pkg['version']}"
                resp = requests.delete(url, auth=(owner, password))
                print(f"Delete response: {resp.status_code}")
                if resp.status_code not in [200, 204]:
                    print(f"Error: {resp.text}")

def upload_packages(host, owner, password, pkg_type, pattern, repo="php-zts", branch="main"):
    # Build set of name-version strings that exist remotely
    remote_names = set()
    try:
        packages = get_remote_packages(host, owner, password, pkg_type)
        remote_names = {f"{p['name']}-{p['version']}" for p in packages}
    except Exception as e:
        print(f"Warning: Could not fetch existing packages: {e}")

    # Cache arch lookups so we only fetch files once per name-version
    arch_cache = {}

    for pkg_file in Path(".").glob(pattern):
        if not pkg_file.is_file():
            continue

        info = get_package_info(pkg_file, pkg_type)
        if not info:
            continue

        name, version, arch, full_name = info

        # Extract el_version for RPM if needed
        el_version = None
        if pkg_type == 'rpm':
            match = re.match(r'.+\.el(\d+)\.(x86_64|aarch64)\.rpm', pkg_file.name)
            if match:
                el_version = f"el{match.group(1)}"

        # Only fetch arch info for packages that exist remotely
        if full_name in remote_names:
            if full_name not in arch_cache:
                link_name = name.replace('_', '-') if pkg_type == 'debian' else name
                arch_cache[full_name] = get_remote_package_archs(host, owner, password, pkg_type, link_name, version)
            if arch in arch_cache[full_name]:
                print(f"Skip: {pkg_file.name} (already exists for {arch})")
                continue

        print(f"Uploading: {pkg_file.name}")
        if pkg_type == 'rpm':
            url = f"{host}/api/packages/{owner}/rpm/{el_version}/upload?sign=true"
        elif pkg_type == 'debian':
            url = f"{host}/api/packages/{owner}/debian/pool/php-zts/main/upload"
        else:
            url = f"{host}/api/packages/{owner}/{pkg_type}/{branch}/{repo}"
        with open(pkg_file, 'rb') as f:
            resp = requests.put(url, files={'file': f}, auth=(owner, password))
            if resp.status_code == 201:
                print(f"Upload successful: {resp.status_code}")
            elif resp.status_code == 409:
                print(f"Skip: {pkg_file.name} (already exists)")
                continue
            else:
                print(f"Upload response: {resp.status_code}")
                print(f"Error: {resp.text}")
                continue

            link_name = name.replace('_', '-') if pkg_type == 'debian' else name
            print(f"Linking: {link_name} to {repo}")
            url = f"{host}/api/v1/packages/{owner}/{pkg_type}/{link_name}/-/link/{repo}"
            resp = requests.post(url, auth=(owner, password))
            print(f"Link response: {resp.status_code}")
            if resp.status_code != 201:
                print(f"Error: {resp.text}")

if __name__ == "__main__":
    args = sys.argv[1:]
    host = host1
    if "--host=2" in args:
        host = host2
        args.remove("--host=2")

    if len(args) < 4:
        print("Usage: script.py [--host=2] <upload|list|delete> <alpine|arch|debian|rpm> <owner> <password> [pattern]")
        print("Examples:")
        print("  script.py upload alpine 85 pass '*.apk'")
        print("  script.py --host=2 upload rpm 85 pass '*.rpm'")
        print("  script.py list alpine 85 pass")
        sys.exit(1)

    action = args[0]
    pkg_type = args[1]
    owner = args[2]
    password = args[3]

    if pkg_type not in ['alpine', 'arch', 'debian', 'rpm']:
        print(f"Error: Invalid package type. Must be alpine, arch, debian, or rpm")
        sys.exit(1)

    if action == "upload":
        pattern = args[4] if len(args) > 4 else "*.apk"
        upload_packages(host, owner, password, pkg_type, pattern)
    elif action == "list":
        pattern = args[4] if len(args) > 4 else None
        list_packages(host, owner, password, pkg_type, pattern)
    elif action == "delete":
        if len(args) < 5:
            print("Error: delete requires a pattern")
            sys.exit(1)
        delete_packages(host, owner, password, pkg_type, args[4])
    else:
        print(f"Unknown action: {action}")
        sys.exit(1)
